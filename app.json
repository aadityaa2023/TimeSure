{
    "expo": {
        "name": "TimeSure",
        "slug": "timesure",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "timesure",
        "userInterfaceStyle": "light",
        "splash": {
            "image": "./assets/images/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#0C831F"
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.timesure.app",
            "infoPlist": {
                "NSLocationWhenInUseUsageDescription": "TimeSure needs your location to show nearby stores and deliver to your address.",
                "NSLocationAlwaysUsageDescription": "TimeSure uses your location for real-time delivery tracking.",
                "NSCameraUsageDescription": "TimeSure needs camera access to upload your profile photo.",
                "NSPhotoLibraryUsageDescription": "TimeSure needs photo library access to select your profile photo."
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/adaptive-icon.png",
                "backgroundColor": "#0C831F"
            },
            "permissions": [
                "ACCESS_FINE_LOCATION",
                "ACCESS_COARSE_LOCATION",
                "CAMERA",
                "READ_EXTERNAL_STORAGE",
                "WRITE_EXTERNAL_STORAGE",
                "RECEIVE_BOOT_COMPLETED",
                "VIBRATE"
            ],
            "package": "com.timesure.app",
            "googleServicesFile": "./google-services.json"
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            "expo-font",
            [
                "expo-location",
                {
                    "locationAlwaysAndWhenInUsePermission": "Allow TimeSure to use your location."
                }
            ],
            [
                "expo-image-picker",
                {
                    "photosPermission": "The app accesses your photos to let you share them with your friends."
                }
            ],
            "expo-secure-store"
        ],
        "experiments": {
            "typedRoutes": true
        },
        "extra": {
            "eas": {
                "projectId": "YOUR_EAS_PROJECT_ID"
            },
            "firebaseApiKey": "AIzaSyCH3lqGAbx3pyInwGUCxC3jFdXTxJBIy0k",
            "firebaseAuthDomain": "timesure-26.firebaseapp.com",
            "firebaseProjectId": "timesure-26",
            "firebaseStorageBucket": "timesure-26.firebasestorage.app",
            "firebaseMessagingSenderId": "755004706807",
            "firebaseAppId": "1:755004706807:android:c18d9274e979df0913a8f2",
            "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
    }
}